<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Notarization requires the hardened runtime, which denies microphone
         capture unless this entitlement is present (NSMicrophoneUsageDescription
         in Info.plist alone is not enough for hardened-runtime builds). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
